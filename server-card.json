{
  "name": "hyperframesrender",
  "title": "HyperFrames Render MCP",
  "description": "A paid remote MCP for HyperFrames, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://hyperframesrender.clauxel.com/",
  "documentationUrl": "https://hyperframesrender.clauxel.com/mcp/",
  "endpointUrl": "https://hyperframesrender.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://hyperframesrender.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://hyperframesrender.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://hyperframesrender.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "creator",
        "name": "Creator",
        "monthlyUsd": 29
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 99
      },
      {
        "id": "studio",
        "name": "Studio",
        "monthlyUsd": 249
      }
    ]
  },
